      }
    },
    "demo-mode-mcp": {
      "type": "stdio",
      "command": "node",
      "args": [
        "{{VAULT_PATH}}/core/scripts/run-dex-mcp.cjs",
        "demo_mode_server.py"
      ],
      "env": {
        "VAULT_PATH": "{{VAULT_PATH}}"
      }
    }
  }
}
