# Dex - API Keys Configuration
#
# NOTE: This file is created automatically during Dex setup if you enable automatic meeting processing.
# Most users don't need to manually edit this file.
#
# ===========================================
# What needs API keys?
# ===========================================
#
# Most Dex features work through Codex and Dex's local MCP/runtime setup - no direct API key needed.
# If you want Dex scripts to use your ChatGPT-authenticated Codex CLI session, run:
#   codex login
#
# API keys are ONLY for:
# - Optional direct-provider fallback
# - Unattended background automation when you prefer API-key auth
#
# Optional auth override for Dex scripts:
# - auto (default): prefer file-backed Codex ChatGPT auth when available, otherwise use API keys,
#   otherwise fall back to a logged-in local Codex ChatGPT session
# - codex-chatgpt: force Codex CLI ChatGPT auth
# - api-key: force direct provider APIs
#
# DEX_LLM_AUTH_MODE=codex-chatgpt
#
# ===========================================
# API Keys (add ONE of these)
# ===========================================
#
# The system auto-detects which provider you have configured when API-key auth is in use.
# Direct-provider priority: OpenAI > Anthropic > Gemini
#
# For local background automation with Codex ChatGPT auth, prefer file-backed auth:
#   ~/.codex/config.toml -> cli_auth_credentials_store = "file"
# Then run: codex login

# Anthropic - optional provider
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (GPT-5.5)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Google Gemini - Has generous free tier
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-your-key-here

# ===========================================
# Optional: Dex product analytics transport
# ===========================================
#
# IMPORTANT:
# - Do NOT commit real analytics secrets to git.
# - Prefer proxy mode so the Pendo ingestion key stays server-side.
#
# Modes:
# - proxy  -> send analytics to your relay endpoint (recommended)
# - direct -> send directly to Pendo (requires PENDO_TRACK_SECRET in env)
DEX_ANALYTICS_MODE=proxy

# Proxy endpoint (recommended):
# Example: https://analytics.dex.example.com/track
DEX_ANALYTICS_ENDPOINT=

# Optional proxy auth token (if your relay requires it)
DEX_ANALYTICS_PROXY_TOKEN=

# Direct-to-Pendo mode only (not recommended for OSS clients):
PENDO_TRACK_SECRET=
